# Server Configuration
PORT=8080

# Database Configuration
DB_NAME=testers_admin
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_HOST=postgres17-testers

# Database SSL Configuration
# Options: disable, require, verify-ca, verify-full
# - require: Encrypts connection, doesn't verify certificate
# - verify-ca: Encrypts and verifies certificate is signed by trusted CA
# - verify-full: Encrypts, verifies certificate, and checks hostname
DB_SSLMODE=require